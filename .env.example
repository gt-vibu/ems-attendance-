# =============================================
# Smart Teams – Environment Variables (TEMPLATE)
# =============================================
# Copy this file to `.env` and fill in real values. `.env` is gitignored and
# must never be committed. Generate strong, unique secrets — do NOT reuse the
# examples here.

# --- Database (PostgreSQL) ---
# Local Docker: the values below. Managed (Neon/Supabase/Render): copy the
# host/user/password/database from the provider and set SQL_SSL=true.
SQL_HOST=127.0.0.1
SQL_PORT=5432
SQL_ADMIN_USER=postgres
SQL_ADMIN_PASSWORD=change-me-strong-password
SQL_DB_NAME=smartteams
# Set to true for any managed Postgres that requires TLS (Neon, Supabase, ...).
# Leave false/unset for local Docker Postgres.
SQL_SSL=false

# --- JWT Secret ---
# REQUIRED in production (the app refuses to start without it). Use a long
# random value, e.g.  openssl rand -base64 48
JWT_SECRET=generate-a-long-random-secret

# --- Super Admin bootstrap (first run of the local JSON fallback only) ---
# If unset, a random one-time password is generated and printed to the server
# console on first run, and must be changed at first login.
SEED_SUPER_ADMIN_EMAIL=admin@example.com
SEED_SUPER_ADMIN_PASSWORD=

# --- App Base URL (used in email activation links) ---
# In production set this to your public https URL (e.g. https://your-domain.com).
APP_BASE_URL=http://localhost:3000

# --- Reverse proxy / TLS (docker-compose.prod.yml + Caddy only) ---
# The domain Caddy serves and auto-provisions a Let's Encrypt cert for. Point
# your DNS A/AAAA record at the server, then Caddy handles HTTPS automatically.
DOMAIN=your-domain.com
ACME_EMAIL=you@example.com

# --- CORS (external/partner API integrations) ---
# Comma-separated allowlist of cross-origin callers. Blank = same-origin only.
# SPLIT DEPLOY: when the frontend is hosted separately (e.g. Vercel), set this
# on the BACKEND to the frontend's origin, e.g. https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=

# --- Split deployment: frontend -> backend URL (FRONTEND build-time only) ---
# Set this in Vercel (NOT on the backend) to the backend's public origin so the
# SPA calls the API cross-origin. Leave blank for the single-process monolith.
#   e.g. VITE_API_BASE_URL=https://your-backend.onrender.com
VITE_API_BASE_URL=

# --- Google Sign-In (existing accounts only; no auto-provisioning) ---
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# --- Reverse Geocoding (optional; WFH home-location addresses) ---
# Uses free OpenStreetMap Nominatim — no API key, no billing. These overrides
# are optional: set NOMINATIM_URL to a self-hosted instance to lift rate limits,
# and NOMINATIM_USER_AGENT to identify your deployment per Nominatim's policy.
# NOMINATIM_URL=https://nominatim.openstreetmap.org
# NOMINATIM_USER_AGENT=SmartTeams-AMSSS/1.0 (your-contact@example.com)

# --- Email Delivery ---
# mail.ts tries in order: Resend API -> Gmail/SMTP -> local file simulation.

# OPTION 1: Resend API (recommended for production)
RESEND_API_KEY=
RESEND_FROM=

# OPTION 2: Gmail SMTP (needs an App Password, not your Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- WebAuthn (device identity — Windows Hello, Touch ID, Android biometric/PIN) ---
# rpID/origin default to APP_BASE_URL's hostname/value; override only if they differ.
# WEBAUTHN_RP_NAME=Attendance & HR Suite
# WEBAUTHN_RP_ID=
# WEBAUTHN_ORIGIN=

# --- Web Push (browser/PWA push notifications for tickets, alerts, approvals) ---
# A dev-only keypair ships here so push works out of the box locally — generate
# your OWN pair for any real deployment: `node -e "console.log(require('web-push').generateVAPIDKeys())"`
# The public key is served to the frontend at runtime via GET /api/push/vapid-public-key
# (see push.routes.ts) — no VITE_ build-time env var needed.
VAPID_PUBLIC_KEY=BP1pwTKDQResRxmkSSSj3ZExg0sqIegBMrmDHA2kU8_WVE-QIFuoEEabyihpiXIyeB0q2zzxDhrYG3PwgIeSdDs
VAPID_PRIVATE_KEY=XkP3L6fDMsCKtqTGeTalGc3bjBVzVkEJGOpahWsE81I
VAPID_SUBJECT=mailto:admin@example.com
