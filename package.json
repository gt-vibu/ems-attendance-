{
  "name": "monorepo-root",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "start": "pnpm --filter @company/admin start",
    "seed": "tsx seed.ts",
    "seed:superadmin": "tsx seed-superadmin.ts",
    "seed:sandbox": "tsx seed-sandbox-tenant.ts",
    "db:generate": "pnpm --filter @company/database db:generate",
    "db:migrate": "pnpm --filter @company/database db:migrate"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "firebase": "^12.16.0",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "turbo": "^2.10.6",
    "typescript": "~7.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide"
    ],
    "overrides": {
      "fast-xml-parser": "^5.10.1"
    }
  }
}